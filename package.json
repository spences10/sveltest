{
	"name": "sveltest-monorepo",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/spences10/sveltest.git"
	},
	"homepage": "https://github.com/spences10/sveltest",
	"bugs": {
		"url": "https://github.com/spences10/sveltest/issues"
	},
	"scripts": {
		"dev": "pnpm --filter @sveltest/website dev",
		"build": "pnpm --filter @sveltest/website build",
		"preview": "pnpm --filter @sveltest/website preview",
		"prepare": "pnpm --filter @sveltest/website prepare",
		"check": "vp check",
		"check:watch": "pnpm --filter @sveltest/website check:watch",
		"format": "vp check --fix && prettier --write '**/*.svelte'",
		"lint": "vp check && eslint --no-warn-ignored '**/*.svelte' && prettier --check '**/*.svelte'",
		"lint:fix": "vp check --fix && eslint --fix --no-warn-ignored '**/*.svelte' && prettier --write '**/*.svelte'",
		"test:unit": "pnpm --filter @sveltest/website test:unit",
		"test:server": "pnpm --filter @sveltest/website test:server",
		"test:client": "pnpm --filter @sveltest/website test:client",
		"test:ssr": "pnpm --filter @sveltest/website test:ssr",
		"test": "pnpm --filter @sveltest/website test",
		"test:e2e": "pnpm --filter @sveltest/website test:e2e",
		"coverage": "pnpm --filter @sveltest/website coverage",
		"validate:tests": "tsx scripts/validation/validate-tests.ts",
		"cli:build": "pnpm --filter sveltest build",
		"cli:dev": "pnpm --filter sveltest dev",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "pnpm cli:build && changeset publish"
	},
	"devDependencies": {
		"@anthropic-ai/claude-agent-sdk": "^0.2.97",
		"@anthropic-ai/sdk": "^0.90.0",
		"@changesets/cli": "2.30.0",
		"dotenv": "^17.4.1",
		"eslint": "^10.2.0",
		"eslint-plugin-svelte": "^3.17.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite-plus": "^0.1.16",
		"zod": "^4.3.6"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@tailwindcss/oxide",
			"esbuild"
		]
	}
}
