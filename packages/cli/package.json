{
	"name": "sveltest",
	"version": "0.0.8",
	"description": "CLI tool to fetch Svelte testing patterns and examples from sveltest.dev",
	"type": "module",
	"bin": {
		"sveltest": "./bin/sveltest.js"
	},
	"exports": {
		".": "./dist/index.js"
	},
	"files": [
		"dist",
		"bin",
		"README.md"
	],
	"scripts": {
		"build": "vp pack",
		"dev": "vp pack --watch",
		"test": "vp test",
		"test:watch": "vp test watch",
		"check": "vp check",
		"check:fix": "vp check --fix",
		"prepublishOnly": "pnpm build"
	},
	"keywords": [
		"svelte",
		"testing",
		"vitest",
		"playwright",
		"cli",
		"sveltest"
	],
	"author": "Scott Spence",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/spences10/sveltest.git",
		"directory": "packages/cli"
	},
	"bugs": {
		"url": "https://github.com/spences10/sveltest/issues"
	},
	"homepage": "https://sveltest.dev",
	"devDependencies": {
		"@types/node": "^25.6.0",
		"typescript": "^6.0.3",
		"vite-plus": "^0.1.18",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"citty": "^0.2.2"
	}
}
